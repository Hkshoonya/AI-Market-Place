# ============================================================
# AI Market Cap — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
# ============================================================

# ── Supabase (required) ─────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Anon / public key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, bypasses RLS.
# Required for admin operations, data sync orchestrator, and seed scripts.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron Security ───────────────────────────────────────────
# Shared secret used to authenticate Vercel Cron requests to /api/cron/*
CRON_SECRET=

# ── Data Source Adapter API Keys (all optional) ─────────────
# These are used by the sync orchestrator to pull data from external APIs.
# Adapters that don't have a key configured will be skipped or use public endpoints.

# Replicate — AI model hosting platform
REPLICATE_API_TOKEN=

# OpenAI — for fetching model metadata
OPENAI_API_KEY=

# Anthropic — for fetching Claude model metadata
ANTHROPIC_API_KEY=

# Google AI (Gemini) — for fetching model metadata
GOOGLE_AI_API_KEY=

# Hugging Face — model hub and papers
HUGGINGFACE_API_TOKEN=

# CivitAI — community AI models
CIVITAI_API_KEY=

# Artificial Analysis — AI benchmarking data
ARTIFICIAL_ANALYSIS_API_KEY=

# ── Stripe (optional — marketplace payments) ────────────────
# Only needed if you enable the marketplace payment flow.

# Stripe secret key (server-side only)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=

# Stripe publishable key (safe to expose in the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── GitHub ────────────────────────────────────────────────────
# GitHub — personal access token for code quality agent (creating issues)
GITHUB_TOKEN=

# ── Site ────────────────────────────────────────────────────
# Public-facing URL of the site. Used for SEO meta tags, OG images, etc.
# Defaults to https://aimarketcap.com in production if not set.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── OpenRouter (optional — free model discovery) ──────────────
# Free API key from openrouter.ai. Works without key but rate limited.
OPENROUTER_API_KEY=

# ── X/Twitter Social Feed (optional) ─────────────────────────
# Self-hosted RSSHub for X/Twitter feeds. Run: docker compose up -d
# Defaults to http://localhost:1200 if not set.
RSSHUB_BASE_URL=http://localhost:1200

# Twitter authentication cookie for RSSHub.
# How to get: Chrome -> x.com -> Login -> F12 -> Application -> Cookies -> x.com
# Copy auth_token + ct0, format as: auth_token=XXX; ct0=XXX
TWITTER_COOKIE=

# ── Blockchain / Crypto Payments (optional) ────────────────────
# Only needed if you enable crypto marketplace payments.

# Solana RPC endpoint
SOLANA_RPC_URL=

# Solana platform master wallet private key (for withdrawals)
SOLANA_MASTER_PRIVATE_KEY=

# EVM chains master wallet private key (Base + Polygon, same key)
EVM_MASTER_PRIVATE_KEY=

# Base L2 RPC endpoint
BASE_RPC_URL=

# Polygon RPC endpoint
POLYGON_RPC_URL=

# USDC contract addresses (defaults to mainnet if not set)
# SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# BASE_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# POLYGON_USDC_CONTRACT=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
