{
  "name": "ai-market-cap",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=20.19.0"
  },
  "volta": {
    "node": "20.19.0",
    "npm": "10.9.7"
  },
  "overrides": {
    "camera-controls": "3.1.0"
  },
  "browserslist": [
    "chrome 111",
    "edge 111",
    "firefox 111",
    "safari 16.4"
  ],
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/clean-next.mjs",
    "build": "next build",
    "start": "node server/custom-server.js",
    "lint": "eslint --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "audit:benchmark-coverage": "node --import tsx scripts/benchmark-coverage-audit.ts",
    "repair:public-ranking-inputs": "node --import tsx scripts/repair-public-ranking-inputs.ts",
    "repair:low-trust-public-signals": "node --import tsx scripts/repair-low-trust-public-signals.ts",
    "cron:launch-signals": "node --import tsx scripts/run-launch-signals-cron.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project unit --no-file-parallelism",
    "test:component": "node scripts/run-component-tests.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "supabase:auth-templates": "node scripts/push-supabase-auth-templates.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@radix-ui/react-popover": "^1.1.15",
