# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron Security
CRON_SECRET=random-secret-for-vercel-cron

# Data Sources (all optional — adapters fallback gracefully)
REPLICATE_API_TOKEN=r8_...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=
HUGGINGFACE_API_TOKEN=hf_...
CIVITAI_API_KEY=
ARTIFICIAL_ANALYSIS_API_KEY=

# OpenRouter (optional — free model discovery)
OPENROUTER_API_KEY=sk-or-v1-...

# X/Twitter Social Feed (optional — docker compose up -d)
RSSHUB_BASE_URL=http://localhost:1200
TWITTER_COOKIE=auth_token=YOUR_AUTH_TOKEN; ct0=YOUR_CT0

# Stripe (optional — marketplace payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# GitHub (optional — code quality agent)
GITHUB_TOKEN=github_pat_...

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Blockchain / Crypto (optional — wallet & crypto payments)
SOLANA_RPC_URL=
SOLANA_MASTER_PRIVATE_KEY=
EVM_MASTER_PRIVATE_KEY=
BASE_RPC_URL=
POLYGON_RPC_URL=
